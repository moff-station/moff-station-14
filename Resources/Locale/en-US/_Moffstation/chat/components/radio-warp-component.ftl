chat-radio-warp-message-wrap = [color={$color}]{$channel} [cmdlink="{$name}" command="warp_to_entity {$source}"] {$verb}, [font={$fontType} size={$fontSize}]“{$message}”[/font][/color]
chat-radio-warp-message-wrap-bold = [color={$color}]{$channel} [cmdlink="{$name}" command="warp_to_entity {$source}"] {$verb}, [font={$fontType} size={$fontSize}][bold]“{$message}”[/bold][/font][/color]

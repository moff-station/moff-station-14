stain-repellent-not-item = { CAPITALIZE(THE($target)) } is too big to be coated.
stain-repellent-failure-already-repellent = { CAPITALIZE(THE($target)) }'s existing coating repels further coating.

stain-repellent-examine-coated = It has a faint, [color=#94E0E2]stain-repellent sheen[/color].

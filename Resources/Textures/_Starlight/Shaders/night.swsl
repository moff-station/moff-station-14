uniform sampler2D SCREEN_TEXTURE;

uniform highp float ShadowGain;
uniform highp float ShadowThreshold;
uniform highp vec3 LumaCoefficients;
uniform highp vec3 TintColor;
uniform highp float TintIntensity;

void fragment()
{
    vec3 c = zTextureSpec(SCREEN_TEXTURE, Pos).rgb;

    float s = 1.0 - smoothstep(0.0, ShadowThreshold, dot(c, LumaCoefficients));

    c *= mix(1.0, ShadowGain, s);
    c = mix(c, c * TintColor, s * TintIntensity);

    COLOR.rgb = c;
}

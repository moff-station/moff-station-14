<controls:ObjectiveConditionsControl
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Systems.Objectives.Controls"
    Margin="2 0">
    <LayoutContainer HorizontalExpand="True" Name="InfoBox">
        <ProgressBar Name="ProgressBar" MinValue="0" MaxValue="1"
                     LayoutContainer.AnchorRight="1"
                     LayoutContainer.AnchorBottom="1"/>
        <BoxContainer LayoutContainer.AnchorRight="1" LayoutContainer.AnchorBottom="1">
            <cc:ProgressTextureRect Name="ProgressTexture" VerticalAlignment="Top" Access="Public" Margin="0 8 0 0"/>
            <Control MinSize="10 0"/>
            <RichTextLabel Name="Title" Access="Public" HorizontalExpand="True" HorizontalAlignment="Left" Margin="0 5 5 5"/>
        </BoxContainer>
    </LayoutContainer>
</controls:ObjectiveConditionsControl>

<controls:FancyWindow xmlns="https://spacestation14.io"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               xmlns:cryogenics="clr-namespace:Content.Client.Medical.Cryogenics"
               MinSize="250 300"
               Resizable="True">
    <BoxContainer Name="Sections"
                  Orientation="Horizontal">

        <BoxContainer Name="CryoSection"
                      VerticalExpand="True"
                      Orientation="Vertical"
                      MinWidth="250"
                      MaxWidth="250">

            <!-- Flavor text -->
            <BoxContainer Orientation="Horizontal"
                          SeparationOverride="10"
                          Margin="8 0 0 8">
                <TextureRect StyleClasses="NTLogoDark"
                             VerticalExpand="True"
                             Stretch="KeepAspectCentered"
                             SetSize="32 32"/>
                <BoxContainer Orientation="Vertical"
                              SeparationOverride="-4">
                    <Label Text="{Loc 'cryomachine-window-product-name'}"
                           StyleClasses="FontLarge"/>
                    <Label Text="{Loc 'cryomachine-window-product-subtitle'}"
                           StyleClasses="LabelSubText"/>
                </BoxContainer>
            </BoxContainer>

            <PanelContainer StyleClasses="LowDivider" />

            <!-- Atmos info -->
            <BoxContainer Orientation="Vertical">
                <Label Text = "Atmosphere :"/>

                <BoxContainer Orientation="Horizontal"
                              SeparationOverride="20"
                              Margin="0 0 0 4">
                    <!-- Pressure -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'cryomachine-window-pressure-text'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="Pressure"/>
                    </BoxContainer>

                    <!-- Temperature -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'cryomachine-window-temperature-text'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="Temperature"/>
                    </BoxContainer>
                </BoxContainer>

                <!-- Gas mix -->
                <Control Margin="0 0 0 22">
                    <controls:SplitBar Name="GasMixChart"
                                       MinHeight="8"
                                       MaxHeight="8"/>
                </Control>

            </BoxContainer>

            <PanelContainer StyleClasses="LowDivider" />

            <!-- Reagents -->
            <Label Text = "Injector :"/>
            <Control HorizontalExpand="True"
                     MinHeight="30">
                <Label Name="NoBeakerText"
                       Text="{Loc 'cryomachine-window-no-beaker'}"
                       FontColorOverride="Gray"
                       VerticalExpand="True"
                       VAlign="Center"/>
                <cryogenics:BeakerBarChart Name="ChemicalsChart"
                                           HorizontalExpand="True"
                                           VerticalExpand="True"/>
            </Control>

            <!-- Buttons -->
            <BoxContainer Orientation="Vertical"
                          Margin="-2 2 -2 0">
                <BoxContainer Orientation="Horizontal">
                    <Button Name="Inject1"
                            Text="{Loc 'cryo-pod-window-inject-1u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject5"
                            Text="{Loc 'cryo-pod-window-inject-5u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject10"
                            Text="{Loc 'cryo-pod-window-inject-10u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject20"
                            Text="{Loc 'cryo-pod-window-inject-20u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="EjectBeakerButton"
                            Text="{Loc 'cryo-pod-window-eject-beaker'}"
                            Disabled="True"
                            StyleClasses="OpenBoth"/>
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>

        <!-- separator-->
        <PanelContainer StyleClasses="LowDivider" VerticalExpand="True" Margin="0 0 0 0" SetWidth="2"/>

        <BoxContainer Name="PatientSection"
                      VerticalExpand="True"
                      Orientation="Vertical"
                      MinWidth="250"
                      MaxWidth="250">

            <BoxContainer Name="CapsulePanel" Orientation="Vertical">
                <BoxContainer Orientation="Horizontal" Margin="0 0 0 5">
                    <SpriteView OverrideDirection="South"
                                Scale="2 2"
                                Name="SpriteView"
                                Access="Public"
                                SetSize="64 64" />
                    <BoxContainer Margin="5 0 0 0" Orientation="Vertical" VerticalAlignment="Top">
                        <RichTextLabel Name="NameLabel"/>
                        <Label Name="SpeciesLabel" VerticalAlignment="Top" StyleClasses="LabelSubText" />
                    </BoxContainer>
                </BoxContainer>

                <PanelContainer StyleClasses="LowDivider" />

                <!-- Organs Checklist -->
                <GridContainer Columns="2"
                               HSeparationOverride="0"
                               VSeparationOverride="6"
                               Margin="6 3 0 0"
                               VerticalExpand="True">
                    <Label Text="{Loc 'cryomachine-capsule-brain-status'}"
                           StyleClasses="LabelSubText"/>
                    <RichTextLabel Name="BrainStatusLabel"
                           Text="{Loc 'cryomachine-organ-absent'}"/>
                    <Label Text="{Loc 'cryomachine-capsule-eyes-status'}"
                           StyleClasses="LabelSubText"/>
                    <RichTextLabel Name="EyesStatusLabel"
                           Text="{Loc 'cryomachine-organ-absent'}"/>
                    <Label Text="{Loc 'cryomachine-capsule-lungs-status'}"
                           StyleClasses="LabelSubText"/>
                    <RichTextLabel Name="LungsStatusLabel"
                           Text="{Loc 'cryomachine-organ-absent'}"/>
                    <Label Text="{Loc 'cryomachine-capsule-heart-status'}"
                           StyleClasses="LabelSubText"/>
                    <RichTextLabel Name="HeartStatusLabel"
                           Text="{Loc 'cryomachine-capsule-organ-absent'}"/>
                    <Label Text="{Loc 'cryomachine-capsule-stomach-status'}"
                           StyleClasses="LabelSubText"/>
                    <RichTextLabel Name="StomachStatusLabel"
                           Text="{Loc 'cryomachine-organ-absent'}"/>
                </GridContainer>

                <PanelContainer StyleClasses="LowDivider" />

                <BoxContainer Orientation="Horizontal">
                    <Button Name="JumpStartBrainButton" Text="Revive" StyleClasses="OpenBoth"/>
                    <Button Name="DetachCapsuleButton" Text="Detach" StyleClasses="OpenBoth"/>
                </BoxContainer>

            </BoxContainer>

        </BoxContainer>


    </BoxContainer>


</controls:FancyWindow>

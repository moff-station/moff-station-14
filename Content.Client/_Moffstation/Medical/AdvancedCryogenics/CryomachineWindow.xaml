<controls:FancyWindow xmlns="https://spacestation14.io"
               xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               xmlns:health="clr-namespace:Content.Client.HealthAnalyzer.UI"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               xmlns:cryogenics="clr-namespace:Content.Client.Medical.Cryogenics"
               MinSize="250 300"
               Resizable="True">
    <BoxContainer Name="Sections"
                  Orientation="Horizontal">

        <BoxContainer Name="CryoSection"
                      VerticalExpand="True"
                      Orientation="Vertical"
                      MinWidth="250"
                      MaxWidth="250">

            <!-- Flavor text -->
            <BoxContainer Orientation="Horizontal"
                          SeparationOverride="10"
                          Margin="8 0 0 8">
                <TextureRect StyleClasses="NTLogoDark"
                             VerticalExpand="True"
                             Stretch="KeepAspectCentered"
                             SetSize="32 32"/>
                <BoxContainer Orientation="Vertical"
                              SeparationOverride="-4">
                    <Label Text="{Loc 'cryomachine-window-product-name'}"
                           StyleClasses="FontLarge"/>
                    <Label Text="{Loc 'cryomachine-window-product-subtitle'}"
                           StyleClasses="LabelSubText"/>
                </BoxContainer>
            </BoxContainer>

            <PanelContainer StyleClasses="LowDivider" />

            <!-- Atmos info -->
            <BoxContainer Orientation="Vertical">
                <Label Text = "Atmosphere :"/>

                <BoxContainer Orientation="Horizontal"
                              SeparationOverride="20"
                              Margin="0 0 0 4">
                    <!-- Pressure -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'cryomachine-window-pressure-text'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="Pressure"/>
                    </BoxContainer>

                    <!-- Temperature -->
                    <BoxContainer Orientation="Vertical">
                        <Label Text="{Loc 'cryomachine-window-temperature-text'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="Temperature"/>
                    </BoxContainer>
                </BoxContainer>

                <!-- Gas mix -->
                <Control Margin="0 0 0 22">
                    <controls:SplitBar Name="GasMixChart"
                                       MinHeight="8"
                                       MaxHeight="8"/>
                </Control>

            </BoxContainer>

            <PanelContainer StyleClasses="LowDivider" />

            <!-- Reagents -->
            <Label Text = "Reagent :"/>
            <Control HorizontalExpand="True"
                     MinHeight="30">
                <Label Name="NoBeakerText"
                       Text="{Loc 'cryomachine-window-no-beaker'}"
                       FontColorOverride="Gray"
                       VerticalExpand="True"
                       VAlign="Center"/>
                <cryogenics:BeakerBarChart Name="ChemicalsChart"
                                           HorizontalExpand="True"
                                           VerticalExpand="True"/>
            </Control>

            <!-- Buttons -->
            <BoxContainer Orientation="Vertical"
                          Margin="-2 2 -2 0">
                <BoxContainer Orientation="Horizontal">
                    <Button Name="Inject1"
                            Text="{Loc 'cryo-pod-window-inject-1u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject5"
                            Text="{Loc 'cryo-pod-window-inject-5u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject10"
                            Text="{Loc 'cryo-pod-window-inject-10u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="Inject20"
                            Text="{Loc 'cryo-pod-window-inject-20u'}"
                            Disabled="True"
                            HorizontalExpand="True"
                            StyleClasses="OpenBoth"/>
                    <Button Name="EjectBeakerButton"
                            Text="{Loc 'cryo-pod-window-eject-beaker'}"
                            Disabled="True"
                            StyleClasses="OpenBoth"/>
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>

        <!-- separator-->
        <Control MinWidth="10"
                 MaxWidth="10"/>

        <BoxContainer Name="PatientSection"
                      VerticalExpand="True"
                      Orientation="Vertical"
                      MinWidth="250"
                      MaxWidth="250">


            <BoxContainer Name="NoCapsulePanel"
                          Visible="False">
                <Label Text="No Capsule Detected"/>
            </BoxContainer>


            <BoxContainer Name="CapsulePanel" Orientation="Vertical">

                <Label Text="Patient Status :"/>
                <!-- Organs panel -->
                <BoxContainer Orientation="Horizontal">

                    <PanelContainer> <!-- previously with VerticalExpand -->
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
                        </PanelContainer.PanelOverride>
                        <BoxContainer HorizontalAlignment="Center" VerticalAlignment="Center">
                            <SpriteView Name="CapsuleSprite" Scale="3 3"/>
                        </BoxContainer>
                    </PanelContainer>

                    <!-- Organs Checklist -->
                    <GridContainer Columns="2"
                                   HSeparationOverride="0"
                                   VSeparationOverride="6"
                                   Margin="6 3 0 0">
                        <Label Text="{Loc 'cryomachine-capsule-brain-status'}"
                                       StyleClasses="LabelSubText"/>
                        <Label Name="BrainStatusLabel"
                               Text="{Loc 'cryomachine-capsule-no-brain'}"
                               FontColorOverride="Orange"/>
                        <Label Text="{Loc 'cryomachine-capsule-eyes-status'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="EyesStatusLabel"
                               Text="{Loc 'cryomachine-capsule-no-eyes'}"
                               FontColorOverride="Orange"/>
                        <Label Text="{Loc 'cryomachine-capsule-lungs-status'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="LungsStatusLabel"
                               Text="{Loc 'cryomachine-capsule-no-lungs'}"
                               FontColorOverride="Orange"/>
                        <Label Text="{Loc 'cryomachine-capsule-heart-status'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="HeartStatusLabel"
                               Text="{Loc 'cryomachine-capsule-no-heart'}"
                               FontColorOverride="Orange"/>
                        <Label Text="{Loc 'cryomachine-capsule-stomach-status'}"
                               StyleClasses="LabelSubText"/>
                        <Label Name="StomachStatusLabel"
                               Text="{Loc 'cryomachine-capsule-no-stomach'}"
                               FontColorOverride="Orange"/>
                    </GridContainer>

                </BoxContainer>

                <!-- General Overview -->

                <BoxContainer Orientation="Horizontal">
                    <Button Name="JumpStartBrainButton" Text="Shock" StyleClasses="OpenBoth"/>
                    <Button Name="DetachCapsuleButton" Text="Detach" StyleClasses="OpenBoth"/>
                </BoxContainer>

            </BoxContainer>

        </BoxContainer>


    </BoxContainer>


</controls:FancyWindow>

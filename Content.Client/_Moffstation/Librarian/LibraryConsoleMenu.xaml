<controls1:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:controls1="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:librarian="clr-namespace:Content.Client._Moffstation.Librarian"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    Title="{Loc 'library-console-menu-title'}"
    MinSize="700 550">
    <BoxContainer Orientation="Vertical">
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#24242b"/>
            </PanelContainer.PanelOverride>
            <GridContainer Columns="2" HorizontalAlignment="Center" HorizontalExpand="True">
                <Button Name="UploadButton" Text="{Loc library-console-upload}" SetHeight="30" Margin="5"/>
                <Button Name="RepoButton" Text="{Loc library-console-repo}" SetHeight="30" Margin="5"/>
            </GridContainer>
        </PanelContainer>
        <PanelContainer StyleClasses="LowDivider" HorizontalExpand="True" SetHeight="2" Margin="0 0 0 5"/>
        <librarian:LibraryUploadWindow Name="UploadWindow"/>
        <librarian:LibraryRepositoryWindow Name="RepositoryWindow" Visible="False"/>
    </BoxContainer>
</controls1:FancyWindow>

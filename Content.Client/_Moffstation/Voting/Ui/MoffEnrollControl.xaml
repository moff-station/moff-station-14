<controls:MoffEnrollControl
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._Moffstation.Voting.Ui"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:xNamespace="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:style="clr-namespace:Content.Client.Stylesheets">
    <PanelContainer.PanelOverride>
        <graphics:StyleBoxFlat BackgroundColor="{xNamespace:Static style:StyleNano.ButtonColorDisabled}" />
    </PanelContainer.PanelOverride>
    <BoxContainer Name="EnrollmentContainer" Orientation="Vertical" VerticalExpand="True" Margin="10">
        <GridContainer Columns="2">
            <BoxContainer Orientation="Vertical">
                <RichTextLabel Name="VoteNameLabel" Text="[bold][font size=16][color=white]Text Title[/color][/font][/bold]" HorizontalExpand="True" RectClipContent="True"/>
                <RichTextLabel Name="VoteDescriptionLabel" Text="Test Desc" HorizontalExpand="True" RectClipContent="True"/>
            </BoxContainer>
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" HorizontalAlignment="Right" MinWidth="30">
                <Button Name="EnrollButton" Text="Enroll"/>
                <Button Name="CharacterSelectionButton" Text="Select Character"/>
                <Button Name="GotoButton" Text="Go To"/>
            </BoxContainer>
        </GridContainer>
        <RichTextLabel Name="TimeLabel"/>
        <ProgressBar Name="Progress" Value="0.5" MinValue="0" MaxValue="1" ModulateSelfOverride="#00ff00" HorizontalExpand="True" SetHeight="5" Margin="0 2 0 5"/>
    </BoxContainer>
</controls:MoffEnrollControl>

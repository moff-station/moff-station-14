<controls:MoffEnrollControl
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._Moffstation.Voting.Ui"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:xNamespace="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:style="clr-namespace:Content.Client.Stylesheets">
    <PanelContainer.PanelOverride>
        <graphics:StyleBoxFlat BackgroundColor="{xNamespace:Static style:StyleNano.ButtonColorDisabled}" />
    </PanelContainer.PanelOverride>
    <BoxContainer Name="EnrollmentContainer" Orientation="Vertical" VerticalExpand="True" Margin="10">
        <BoxContainer Name="HeaderRow" Orientation="Horizontal">
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" HorizontalAlignment="Left">
                <RichTextLabel Name="VoteNameLabel" HorizontalExpand="True" RectClipContent="True"/>
                <RichTextLabel Name="VoteDescriptionLabel" HorizontalExpand="True" RectClipContent="True" MaxWidth="270"/>
            </BoxContainer>
            <BoxContainer Name="ButtonsContainer" Orientation="Vertical" HorizontalAlignment="Right" MinWidth="100">
                <Button Name="EnrollButton" ToggleMode="True" Text="Enroll"/>
                <Button Name="CharacterSelectionButton" Text="Select Character"/>
                <Button Name="GotoButton" Text="Go To"/>
            </BoxContainer>
        </BoxContainer>
        <RichTextLabel Name="TimeLabel"/>
        <ProgressBar Name="TimerProgress" Value="0.5" MinValue="0" MaxValue="1" ModulateSelfOverride="#00ff00" HorizontalExpand="True" SetHeight="5" Margin="0 2 0 5"/>
    </BoxContainer>
</controls:MoffEnrollControl>
